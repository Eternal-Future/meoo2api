# ── 服务配置 ──
HOST=127.0.0.1
PORT=8000

# ── 鉴权配置 ──
# API Key，为空则不启用鉴权。设置后客户端需在 Authorization: Bearer <key> 中传入
# API_KEY=sk-your-secret-key-here

# ── Meoo 后端配置 ──
# 认证 Cookie（从浏览器开发者工具中复制完整 cookie 字符串）
# 至少需要包含: oneday_sid, login_oneday_ticket, lang
MEOO_COOKIE=oneday_sid=xxx; login_oneday_ticket=xxx; lang=zh

# Meoo API 基础地址
MEOO_BASE_URL=https://meoo.com

# 默认项目 ID（可选，不填则自动创建）
# MEOO_PROJECT_ID=wwfjezwyjr7d

# 是否跳过内容安全检测（默认跳过）
MEOO_SKIP_SECURITY=true

# 轮询超时时间（秒）
MEOO_POLL_TIMEOUT=120
